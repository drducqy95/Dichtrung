### 2. Global State Files Schema

#### [NEW] [global_config.json](file:///d:/Dichtrung/Global State/global_config.json)

Quy tắc dịch chung, áp dụng cho TẤT CẢ project branch:

```json
{
  "metadata": {
    "version": "1.0",
    "last_updated": "",
    "description": "Quy tắc dịch thuật toàn cục cho repo Dichtrung"
  },
  "default_settings": {
    "target_language": "vi",
    "reflection_max_iterations": 3,
    "pronoun_mode": "hybrid",
    "sanitization": {
      "ban_cjk_in_output": true,
      "description": "Output KHÔNG được chứa ký tự CJK (Trung/Nhật/Hàn)"
    }
  },
  "naming_conventions": {
    "default_name_setting": "phien_am",
    "description": "Mặc định phiên âm Hán-Việt cho truyện phương Đông"
  },
  "style_rules": {
    "output_language": "vi",
    "tone": "Văn chương tiếng Việt tự nhiên, mượt mà",
    "forbidden_patterns": ["ký tự Trung Quốc trong output", "dịch máy thô"],
    "required_patterns": ["Xưng hô phải nhất quán theo characters.json"]
  },
  "genre_defaults": {
    "eastern_fiction": {
      "sub_genres": ["xianxia", "wuxia", "xuyen_khong", "do_thi"],
      "name_setting": "phien_am",
      "tone": "Cổ phong / Hiện đại tùy sub_genre"
